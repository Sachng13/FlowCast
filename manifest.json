{
  "manifest_version": 3,
  "name": "FlowCast",
  "version": "1.1.1",
  "description": "Premium screen recording with camera overlay, live annotations, and real-time transcription — built for async communication.",

  "permissions": [
    "offscreen",
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],

  "host_permissions": ["<all_urls>"],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "FlowCast",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background/service-worker.js"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+L"
      },
      "description": "Open FlowCast"
    }
  },

  "web_accessible_resources": [
    {
      "resources": ["content/content.css", "camera/bubble.html", "camera/bubble.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
